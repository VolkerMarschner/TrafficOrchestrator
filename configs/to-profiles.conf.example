# ============================================================
# Traffic Orchestrator — Master config with Profile system
# v0.4.12 example
#
# Save as  to.conf  and run  ./trafficorch  (no arguments).
# ============================================================

[MASTER]
PORT        = 9000
PSK         = ChangeMe2026!
TTL         = 300
PROFILE_DIR = ./profiles     # directory containing *.profile files

# ─── Named targets ───────────────────────────────────────────
# Format:  NAME = IP  #tag:<tagname>
#
# IMPORTANT — tag syntax rules:
#   CORRECT:   CLIENT1 = 10.0.0.10  #tag:client
#   WRONG:     CLIENT1 = 10.0.0.10  [#client:client]   ← brackets corrupt the IP!
#   WRONG:     CLIENT1 = 10.0.0.10  #client:client     ← missing "tag:" prefix, tag ignored!
#
# The keyword is exactly  #tag:  — everything else is not recognised.
# Tags are referenced in profile rules as  group:<tagname>  (e.g. group:client).
# Multiple tags per host: add multiple  #tag:  tokens on the same line.
#   Example:  SRV1 = 10.0.0.5  #tag:web #tag:dmz

[TARGETS]
DC1         = 10.0.0.1   #tag:dc
DC2         = 10.0.0.2   #tag:dc
CLIENT1     = 10.0.0.10  #tag:client
CLIENT2     = 10.0.0.11  #tag:client
WEB1        = 10.0.0.20  #tag:web
FS1         = 10.0.0.30  #tag:fileserver

# ─── Profile assignments ──────────────────────────────────────
# Format:  <target-name or IP> = <profile-name>[, <profile-name>, ...]
#
# IMPORTANT — use the profile NAME, not the filename:
#   The profile name is the  NAME =  value from the profile's [META] section,
#   NOT the filename.  Do NOT include the  .profile  extension here.
#
#   CORRECT:   CLIENT1 = windows_client          ← matches NAME = windows_client in [META]
#   WRONG:     CLIENT1 = windows_client.profile  ← extension causes "profile not found" error
#
# Multiple profiles are merged — rules from all assigned profiles
# are applied to the agent.

[ASSIGNMENTS]
DC1         = domain_controller
DC2         = domain_controller
CLIENT1     = windows_client
CLIENT2     = windows_client
WEB1        = web_server
FS1         = base_windows

# ─── Optional direct rules (legacy format, fully compatible) ──
# Direct rules and profile rules are additive.
# Leave this section empty to rely entirely on profiles.

[RULES]
# TCP   SELF  ANY   9999  60  1   #custom-keepalive
