# ============================================================================
# Traffic Orchestrator — Ansible group variables
#
# This file is generated automatically by deploy.sh from Terraform outputs.
# DO NOT commit the populated all.yml — it contains the PSK.
# This .example file is safe to commit and documents the expected variables.
# ============================================================================

# Pre-shared key for the TrafficOrchestrator control channel.
# Generated by Terraform (random_password.trafficorch_psk).
trafficorch_psk: "GENERATED_BY_DEPLOY_SH"

# Private IP of the jumphost within the VNet.
# Agents connect to this address for both the control channel (9000)
# and binary download (9001).
trafficorch_master_ip: "10.0.1.X"

# Public IP of the jumphost — used for status checks from outside.
trafficorch_master_public_ip: "X.X.X.X"

# Local path to the Linux TrafficOrchestrator binary on the Ansible controller.
# The master playbook uploads this; agents bootstrap from the master via HTTP.
trafficorch_binary_local: "/path/to/trafficorch-linux-amd64"

# Local path to the profiles directory on the Ansible controller.
trafficorch_profiles_local: "/path/to/TrafficOrchestrator/profiles"
