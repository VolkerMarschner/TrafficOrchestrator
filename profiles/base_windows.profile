# ============================================================
# Traffic Profile: Base Windows
#
# Common background traffic generated by any Windows host.
# Intended to be used as a parent via EXTENDS in other profiles
# rather than assigned directly to hosts.
# ============================================================

[META]
NAME        = base_windows
DESCRIPTION = Common Windows background traffic (NTP, WMI/RPC)
VERSION     = 1.0
TAGS        = windows, base

[RULES]
# PROTO   ROLE     SRC   DST   PORT  INTV  CNT  #name
# --- NTP time sync ---
UDP       connect  SELF  ANY   123   60    1    #ntp-sync

# --- WMI / RPC endpoint mapper ---
TCP       connect  SELF  ANY   135   60    1    #wmi-rpc
