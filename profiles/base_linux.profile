# ============================================================
# Traffic Profile: Base Linux
#
# Common background traffic generated by any Linux host.
# Intended to be used as a parent via EXTENDS in other profiles
# rather than assigned directly to hosts.
# ============================================================

[META]
NAME        = base_linux
DESCRIPTION = Common Linux background traffic (NTP, SSH, syslog)
VERSION     = 1.0
TAGS        = linux, base

[RULES]
# PROTO   ROLE     SRC   DST   PORT  INTV  CNT  #name

# --- NTP time sync ---
UDP       connect  SELF  ANY   123   60    1    #ntp-sync

# --- SSH inbound (management access) ---
TCP       listen   SELF  -     22    -     -    #ssh-listener

# --- Syslog outbound to log aggregator ---
UDP       connect  SELF  ANY   514   30    1    #syslog-out
