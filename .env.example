# ─────────────────────────────────────────────────────────────────────────────
# Traffic Orchestrator – environment variable template
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# Pre-shared key used to authenticate every master↔agent connection.
# Rules:
#   • Minimum 8 characters
#   • Must contain at least one uppercase letter, one lowercase letter, one digit
#   • Master and all agents must use the same key
#   • Can also be set via the --psk flag (env var takes lower priority than CLI flag)
TRAFFICORCH_PSK=ChangeMe-Set-A-Strong-Key1

# Directory where log files (traffic.log, agent.log) are written.
# Defaults to the current working directory when unset.
# The process must have write permission to this directory.
TRAFFICORCH_LOG_DIR=/var/log/trafficorch
